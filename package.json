{
  "name": "todo-app",
  "private": true,
  "version": "0.0.0",
  "packageManager": "yarn@4.3.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "firebase:rules": "npx firebase-tools deploy --only firestore:rules",
    "test": "vitest run",
    "test:rules": "FIREBASE_PROJECT_ID=todo-app-rules-test npx firebase-tools emulators:exec --project todo-app-rules-test --only firestore \"vitest run tests/firestore.rules.test.ts\"",
    "test:e2e": "FIREBASE_PROJECT_ID=todo-app-e2e firebase emulators:exec --project todo-app-e2e --only firestore,auth,storage \"playwright test\"",
    "test:coverage": "vitest run --coverage --reporter=default --no-color",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@radix-ui/react-toolbar": "^1.1.11",
    "@tiptap/core": "^3.23.6",
    "@tiptap/extension-link": "^3.23.6",
    "@tiptap/extension-placeholder": "^3.23.6",
    "@tiptap/extension-underline": "^3.23.6",
    "@tiptap/extensions": "^3.23.6",
    "@tiptap/pm": "^3.23.6",
    "@tiptap/react": "^3.23.6",
    "@tiptap/starter-kit": "^3.23.6",
    "firebase": "^12.11.0",
    "lucide-react": "^1.17.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-icons": "^5.6.0",
    "react-router-dom": "^7.16.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@firebase/rules-unit-testing": "^5.0.1",
    "@playwright/test": "^1.55.0",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "4.1.6",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "firebase-tools": "^15.19.0",
    "globals": "^17.4.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4",
    "vitest": "^4.1.6"
  }
}
