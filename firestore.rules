rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isTimestamp(value) {
      return value is timestamp;
    }

    function isNonEmptyString(value) {
      return value is string && value.size() > 0;
    }

    function isStringList(value) {
      return value is list;
    }

    function isTodoFilesList(value) {
      return value is list;
    }

    function isTodoLinksList(value) {
      return value is list;
    }

    function isTodoTagsList(value) {
      return value is list;
    }

    function isTodoChecklist(value) {
      return value is map
        && value.keys().hasAll(['title', 'items'])
        && value.keys().hasOnly(['title', 'items'])
        && isNonEmptyString(value.title)
        && value.items is list;
    }

    function isTodoChecklistsList(value) {
      return value is list;
    }

    function isTodoPayload(data) {
      return data.keys().hasAll([
          'entityType',
          'userId',
          'title',
          'status',
          'boardId',
          'columnId',
          'weight',
          'createdAt',
          'updatedAt'
        ])
        && data.keys().hasOnly([
          'entityType',
          'userId',
          'title',
          'description',
          'tags',
          'archived',
          'blockedReason',
          'dueDate',
          'isCompleted',
          'completedAt',
          'remindOneDayBefore',
          'reminderScheduledAt',
          'status',
          'boardId',
          'columnId',
          'weight',
          'comments',
          'files',
          'links',
          'checklist',
          'checklists',
          'createdAt',
          'updatedAt'
        ])
        && data.entityType == 'todo'
        && isNonEmptyString(data.userId)
        && isNonEmptyString(data.title)
        && (!('description' in data) || data.description is string)
        && (!('tags' in data) || isTodoTagsList(data.tags))
        && (!('archived' in data) || data.archived is bool)
        && (!('blockedReason' in data) || data.blockedReason == null || data.blockedReason is string)
        && (!('dueDate' in data) || data.dueDate == null || data.dueDate is string)
        && (!('isCompleted' in data) || data.isCompleted is bool)
        && (!('completedAt' in data) || data.completedAt == null || data.completedAt is string)
        && (!('remindOneDayBefore' in data) || data.remindOneDayBefore is bool)
        && (!('reminderScheduledAt' in data) || data.reminderScheduledAt == null || data.reminderScheduledAt is string)
        && isNonEmptyString(data.status)
        && isNonEmptyString(data.boardId)
        && isNonEmptyString(data.columnId)
        && data.weight is number
        && (!('comments' in data) || data.comments is list)
        && (!('files' in data) || isTodoFilesList(data.files))
        && (!('links' in data) || isTodoLinksList(data.links))
        && (!('checklist' in data) || isTodoChecklist(data.checklist))
        && (!('checklists' in data) || isTodoChecklistsList(data.checklists))
        && isTimestamp(data.createdAt)
        && isTimestamp(data.updatedAt);
    }

    function isTodoLikePayload(data) {
      return data.keys().hasAll([
          'userId',
          'title',
          'status',
          'boardId',
          'columnId',
          'weight',
          'createdAt',
          'updatedAt'
        ])
        && data.keys().hasOnly([
          'entityType',
          'userId',
          'title',
          'description',
          'tags',
          'archived',
          'blockedReason',
          'dueDate',
          'isCompleted',
          'completedAt',
          'remindOneDayBefore',
          'reminderScheduledAt',
          'status',
          'boardId',
          'columnId',
          'weight',
          'comments',
          'files',
          'links',
          'checklist',
          'checklists',
          'createdAt',
          'updatedAt'
        ])
        && (!('entityType' in data) || data.entityType == 'todo')
        && isNonEmptyString(data.userId)
        && isNonEmptyString(data.title)
        && (!('description' in data) || data.description is string)
        && (!('tags' in data) || isTodoTagsList(data.tags))
        && (!('archived' in data) || data.archived is bool)
        && (!('blockedReason' in data) || data.blockedReason == null || data.blockedReason is string)
        && (!('dueDate' in data) || data.dueDate == null || data.dueDate is string)
        && (!('isCompleted' in data) || data.isCompleted is bool)
        && (!('completedAt' in data) || data.completedAt == null || data.completedAt is string)
        && (!('remindOneDayBefore' in data) || data.remindOneDayBefore is bool)
        && (!('reminderScheduledAt' in data) || data.reminderScheduledAt == null || data.reminderScheduledAt is string)
        && isNonEmptyString(data.status)
        && isNonEmptyString(data.boardId)
        && isNonEmptyString(data.columnId)
        && data.weight is number
        && (!('comments' in data) || data.comments is list)
        && (!('files' in data) || isTodoFilesList(data.files))
        && (!('links' in data) || isTodoLinksList(data.links))
        && (!('checklist' in data) || isTodoChecklist(data.checklist))
        && (!('checklists' in data) || isTodoChecklistsList(data.checklists))
        && isTimestamp(data.createdAt)
        && isTimestamp(data.updatedAt);
    }

    function isDashboardPayload(data) {
      return data.entityType == 'dashboard'
        && isNonEmptyString(data.userId)
        && isNonEmptyString(data.name)
        && (!('order' in data) || data.order is number)
        && (!('columns' in data) || (data.columns is list && data.columns.size() > 0))
        && (!('sharedWith' in data) || isStringList(data.sharedWith))
        && (!('sharedWithEmails' in data) || isStringList(data.sharedWithEmails))
        && (!('createdAt' in data) || isTimestamp(data.createdAt))
        && (!('updatedAt' in data) || isTimestamp(data.updatedAt));
    }

    function isDashboardLikePayload(data) {
      return (!('entityType' in data) || data.entityType == 'dashboard')
        && isNonEmptyString(data.userId)
        && isNonEmptyString(data.name)
        && (!('order' in data) || data.order is number)
        && (!('columns' in data) || (data.columns is list && data.columns.size() > 0))
        && (!('sharedWith' in data) || isStringList(data.sharedWith))
        && (!('sharedWithEmails' in data) || isStringList(data.sharedWithEmails))
        && (!('createdAt' in data) || isTimestamp(data.createdAt))
        && (!('updatedAt' in data) || isTimestamp(data.updatedAt));
    }

    function isValidPayload(data) {
      return data.entityType == 'todo'
        ? isTodoPayload(data)
        : data.entityType == 'dashboard' && isDashboardPayload(data);
    }

    function isOwnerFromResource() {
      return isSignedIn() && resource.data.userId == request.auth.uid;
    }

    function signedInEmail() {
      return request.auth.token.email is string
        ? request.auth.token.email
        : null;
    }

    function profileEmail() {
      let profileDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return profileDoc.data != null && profileDoc.data.email is string
        ? profileDoc.data.email
        : null;
    }

    function isDashboardMember(dashboardData) {
      return dashboardData != null && (
        dashboardData.userId == request.auth.uid
        || (dashboardData.sharedWith is list && dashboardData.sharedWith.hasAny([request.auth.uid]))
        || (
          dashboardData.sharedWithEmails is list
          && (
            (signedInEmail() != null && dashboardData.sharedWithEmails.hasAny([signedInEmail()]))
            || (profileEmail() != null && dashboardData.sharedWithEmails.hasAny([profileEmail()]))
          )
        )
      );
    }

    function canAccessDashboard(dashboardId) {
      let dashboardDoc = get(/databases/$(database)/documents/todos/$(dashboardId));
      return isSignedIn()
        && dashboardDoc.data != null
        && (!('entityType' in dashboardDoc.data) || dashboardDoc.data.entityType == 'dashboard')
        && isDashboardMember(dashboardDoc.data);
    }

    function isTodoOwnerUpdate(nextData, currentData) {
      let changedKeys = nextData.diff(currentData).changedKeys();
      let canChangeBoard = !('boardId' in nextData) || (
        isNonEmptyString(nextData.boardId)
        && canAccessDashboard(nextData.boardId)
      );

      return ('userId' in currentData)
        && changedKeys.hasOnly([
          'title',
          'description',
          'tags',
          'archived',
          'blockedReason',
          'comments',
          'files',
          'links',
          'checklist',
          'checklists',
          'dueDate',
          'isCompleted',
          'completedAt',
          'remindOneDayBefore',
          'reminderScheduledAt',
          'status',
          'columnId',
          'boardId',
          'weight',
          'updatedAt'
        ])
        && (!('title' in nextData) || isNonEmptyString(nextData.title))
        && (!('description' in nextData) || nextData.description is string)
        && (!('tags' in nextData) || isTodoTagsList(nextData.tags))
        && (!('archived' in nextData) || nextData.archived is bool)
        && (!('blockedReason' in nextData) || nextData.blockedReason == null || nextData.blockedReason is string)
        && (!('comments' in nextData) || nextData.comments is list)
        && (!('files' in nextData) || isTodoFilesList(nextData.files))
        && (!('links' in nextData) || isTodoLinksList(nextData.links))
        && (!('checklist' in nextData) || isTodoChecklist(nextData.checklist))
        && (!('checklists' in nextData) || isTodoChecklistsList(nextData.checklists))
        && (!('dueDate' in nextData) || nextData.dueDate == null || nextData.dueDate is string)
        && (!('isCompleted' in nextData) || nextData.isCompleted is bool)
        && (!('completedAt' in nextData) || nextData.completedAt == null || nextData.completedAt is string)
        && (!('remindOneDayBefore' in nextData) || nextData.remindOneDayBefore is bool)
        && (!('reminderScheduledAt' in nextData) || nextData.reminderScheduledAt == null || nextData.reminderScheduledAt is string)
        && (!('status' in nextData) || isNonEmptyString(nextData.status))
        && (!('columnId' in nextData) || isNonEmptyString(nextData.columnId))
        && (!('weight' in nextData) || nextData.weight is number)
        && ('updatedAt' in nextData)
        && nextData.updatedAt is timestamp
        && (!('userId' in nextData) || nextData.userId == currentData.userId)
        && canChangeBoard;
    }

    function isTodoSharedCollaboratorUpdate(nextData, currentData) {
      let changedKeys = nextData.diff(currentData).changedKeys();
      let canChangeWorkflow = !changedKeys.hasAny(['status', 'columnId'])
        || (
          isNonEmptyString(nextData.status)
          && isNonEmptyString(nextData.columnId)
          && nextData.status == nextData.columnId
        );

      return ('userId' in nextData)
        && ('userId' in currentData)
        && nextData.userId == currentData.userId
        && ('boardId' in nextData)
        && ('boardId' in currentData)
        && nextData.boardId == currentData.boardId
        && changedKeys.hasOnly([
          'comments',
          'files',
          'links',
          'tags',
          'checklist',
          'checklists',
          'archived',
          'blockedReason',
          'dueDate',
          'isCompleted',
          'completedAt',
          'remindOneDayBefore',
          'reminderScheduledAt',
          'status',
          'columnId',
          'updatedAt'
        ])
        && canChangeWorkflow
        && (!('comments' in nextData) || nextData.comments is list)
        && (!('files' in nextData) || nextData.files is list)
        && (!('links' in nextData) || nextData.links is list)
        && (!('tags' in nextData) || isTodoTagsList(nextData.tags))
        && (!('checklist' in nextData) || isTodoChecklist(nextData.checklist))
        && (!('checklists' in nextData) || isTodoChecklistsList(nextData.checklists))
        && (!('archived' in nextData) || nextData.archived is bool)
        && (!('blockedReason' in nextData) || nextData.blockedReason == null || nextData.blockedReason is string)
        && (!('dueDate' in nextData) || nextData.dueDate == null || nextData.dueDate is string)
        && (!('isCompleted' in nextData) || nextData.isCompleted is bool)
        && (!('completedAt' in nextData) || nextData.completedAt == null || nextData.completedAt is string)
        && (!('remindOneDayBefore' in nextData) || nextData.remindOneDayBefore is bool)
        && (!('reminderScheduledAt' in nextData) || nextData.reminderScheduledAt == null || nextData.reminderScheduledAt is string)
        && (!('status' in nextData) || isNonEmptyString(nextData.status))
        && (!('columnId' in nextData) || isNonEmptyString(nextData.columnId))
        && ('updatedAt' in nextData)
        && nextData.updatedAt is timestamp;
    }

    function isUsersPayload(data, userId) {
      return userId == request.auth.uid
        && (!('email' in data) || data.email is string)
        && (!('updatedAt' in data) || isTimestamp(data.updatedAt));
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && isUsersPayload(request.resource.data, userId);
      allow delete: if false;
    }

    match /todos/{docId} {
      allow get: if isSignedIn() && (
        (resource.data.entityType == 'dashboard')
        || (resource.data.sharedWith is list && resource.data.sharedWith.hasAny([request.auth.uid]))
        || (
          resource.data.sharedWithEmails is list
          && (
            (signedInEmail() != null && resource.data.sharedWithEmails.hasAny([signedInEmail()]))
            || (profileEmail() != null && resource.data.sharedWithEmails.hasAny([profileEmail()]))
          )
        )
        || isDashboardMember(resource.data)
        || ((resource.data.entityType == 'todo' || !('entityType' in resource.data)) && (
          resource.data.userId == request.auth.uid
          || (resource.data.boardId is string && canAccessDashboard(resource.data.boardId))
        ))
      );

      allow list: if isSignedIn();

      allow create: if isSignedIn()
        && isValidPayload(request.resource.data)
        && request.resource.data.userId == request.auth.uid
        && (
          (request.resource.data.entityType == 'dashboard' && request.resource.data.userId == request.auth.uid)
          || (request.resource.data.entityType == 'todo' && canAccessDashboard(request.resource.data.boardId))
        );

      allow update: if isSignedIn()
        && (
          (resource.data.entityType == 'dashboard'
            && isValidPayload(request.resource.data)
            && isOwnerFromResource()
            && request.resource.data.userId == resource.data.userId)
          || (((resource.data.entityType == 'todo') || !('entityType' in resource.data)) && (
            (isOwnerFromResource()
              && isTodoOwnerUpdate(request.resource.data, resource.data)
              && (!('entityType' in request.resource.data) || request.resource.data.entityType == resource.data.entityType))
            || (
              ('boardId' in resource.data)
              && resource.data.boardId is string
              && canAccessDashboard(resource.data.boardId)
              && isTodoSharedCollaboratorUpdate(request.resource.data, resource.data)
            )
          ))
        );

      allow delete: if isSignedIn() && isOwnerFromResource();
    }
  }
}
