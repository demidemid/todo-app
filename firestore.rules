rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isTimestamp(value) {
      return value is timestamp;
    }

    function isNonEmptyString(value) {
      return value is string && value.size() > 0;
    }

    function isStringList(value) {
      return value is list && value.all(item, item is string);
    }

    function isDashboardColumn(column) {
      return column is map
        && column.keys().hasOnly(['id', 'name', 'order', 'isDone'])
        && isNonEmptyString(column.id)
        && isNonEmptyString(column.name)
        && column.order is int
        && column.isDone is bool;
    }

    function isComment(comment, docId) {
      return comment is map
        && comment.keys().hasOnly(['id', 'todoId', 'userId', 'userEmail', 'text', 'createdAt'])
        && isNonEmptyString(comment.id)
        && comment.todoId == docId
        && isNonEmptyString(comment.userId)
        && (!('userEmail' in comment) || comment.userEmail is string)
        && isNonEmptyString(comment.text)
        && isTimestamp(comment.createdAt);
    }

    function isTodoPayload(data, docId) {
      return data.keys().hasAll([
          'entityType',
          'userId',
          'title',
          'status',
          'boardId',
          'columnId',
          'weight',
          'createdAt',
          'updatedAt'
        ])
        && data.keys().hasOnly([
          'entityType',
          'userId',
          'title',
          'description',
          'status',
          'boardId',
          'columnId',
          'weight',
          'comments',
          'createdAt',
          'updatedAt'
        ])
        && data.entityType == 'todo'
        && isNonEmptyString(data.userId)
        && isNonEmptyString(data.title)
        && (!('description' in data) || data.description is string)
        && isNonEmptyString(data.status)
        && isNonEmptyString(data.boardId)
        && isNonEmptyString(data.columnId)
        && data.weight is number
        && (!('comments' in data) || (data.comments is list && data.comments.all(comment, isComment(comment, docId))))
        && isTimestamp(data.createdAt)
        && isTimestamp(data.updatedAt);
    }

    function isDashboardPayload(data) {
      return data.keys().hasAll(['entityType', 'userId', 'name', 'order', 'columns', 'createdAt', 'updatedAt'])
        && data.keys().hasOnly([
          'entityType',
          'userId',
          'name',
          'order',
          'columns',
          'sharedWith',
          'sharedWithEmails',
          'createdAt',
          'updatedAt'
        ])
        && data.entityType == 'dashboard'
        && isNonEmptyString(data.userId)
        && isNonEmptyString(data.name)
        && data.order is int
        && data.columns is list
        && data.columns.size() > 0
        && data.columns.all(column, isDashboardColumn(column))
        && (!('sharedWith' in data) || isStringList(data.sharedWith))
        && (!('sharedWithEmails' in data) || isStringList(data.sharedWithEmails))
        && isTimestamp(data.createdAt)
        && isTimestamp(data.updatedAt);
    }

    function isValidPayload(data, docId) {
      return data.entityType == 'todo'
        ? isTodoPayload(data, docId)
        : data.entityType == 'dashboard' && isDashboardPayload(data);
    }

    function isOwnerFromResource() {
      return isSignedIn() && resource.data.userId == request.auth.uid;
    }

    function isDashboardMember(dashboardData) {
      return dashboardData.userId == request.auth.uid
        || (dashboardData.sharedWith is list && dashboardData.sharedWith.hasAny([request.auth.uid]));
    }

    function canAccessDashboard(dashboardId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/todos/$(dashboardId))
        && get(/databases/$(database)/documents/todos/$(dashboardId)).data.entityType == 'dashboard'
        && isDashboardMember(get(/databases/$(database)/documents/todos/$(dashboardId)).data);
    }

    function isUsersPayload(data, userId) {
      return data.keys().hasOnly(['email', 'updatedAt'])
        && isNonEmptyString(data.email)
        && isTimestamp(data.updatedAt)
        && userId == request.auth.uid;
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && isUsersPayload(request.resource.data, userId);
      allow delete: if false;
    }

    match /todos/{docId} {
      allow read: if isSignedIn() && (
        (resource.data.entityType == 'dashboard' && isDashboardMember(resource.data))
        || (resource.data.entityType == 'todo' && canAccessDashboard(resource.data.boardId))
      );

      allow create: if isSignedIn()
        && isValidPayload(request.resource.data, docId)
        && (
          (request.resource.data.entityType == 'dashboard' && request.resource.data.userId == request.auth.uid)
          || (
            request.resource.data.entityType == 'todo'
            && request.resource.data.userId == request.auth.uid
            && canAccessDashboard(request.resource.data.boardId)
          )
        );

      allow update: if isSignedIn()
        && request.resource.data.entityType == resource.data.entityType
        && isValidPayload(request.resource.data, docId)
        && (
          (
            resource.data.entityType == 'dashboard'
            && isOwnerFromResource()
            && request.resource.data.userId == resource.data.userId
          )
          || (
            resource.data.entityType == 'todo'
            && canAccessDashboard(resource.data.boardId)
            && canAccessDashboard(request.resource.data.boardId)
            && request.resource.data.userId == resource.data.userId
          )
        );

      allow delete: if isSignedIn() && (
        (resource.data.entityType == 'dashboard' && isOwnerFromResource())
        || (resource.data.entityType == 'todo' && canAccessDashboard(resource.data.boardId))
      );
    }
  }
}
